{
  "name": "@artidv1/widget",
  "version": "0.1.0",
  "description": "Embeddable ArtID museum-passport widget — mints ENS subdomain museum sites under artid.eth for any NFT.",
  "license": "MIT",
  "homepage": "https://artid.eth.link",
  "repository": {
    "type": "git",
    "url": "https://github.com/RWA-ID/artid"
  },
  "keywords": ["artid", "ens", "nft", "ipfs", "ethereum", "widget"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./widget.js": "./dist/widget.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
